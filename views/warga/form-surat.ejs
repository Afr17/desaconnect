<%- include('../partials/header') %>
<%- include('../partials/navbar-warga') %>

<main class="max-w-3xl mx-auto px-4 py-12">
  <div class="mb-8">
    <a href="/warga/dashboard" class="text-hijau-600 hover:text-hijau-700 text-sm font-semibold flex items-center gap-1 mb-4">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Kembali ke Dashboard
    </a>
    <h1 class="text-3xl font-extrabold text-slate-900">Ajukan Surat Keterangan</h1>
    <p class="text-slate-500">Silakan isi formulir di bawah ini dengan lengkap dan benar.</p>
  </div>

  <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-8">
    <%- include('../partials/flash') %>
    
    <form action="/warga/ajukan" method="POST" class="space-y-6">
      <!-- Jenis Surat -->
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Jenis Surat</label>
        <select name="jenis_surat" required class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-hijau-400 transition bg-slate-50">
          <option value="" disabled selected>Pilih jenis surat...</option>
          <option value="Surat Keterangan Domisili">Surat Keterangan Domisili</option>
          <option value="Surat Keterangan Tidak Mampu">Surat Keterangan Tidak Mampu (SKTM)</option>
          <option value="Surat Keterangan Usaha">Surat Keterangan Usaha</option>
          <option value="Surat Keterangan Kelakuan Baik">Surat Keterangan Kelakuan Baik</option>
          <option value="Surat Keterangan Kematian">Surat Keterangan Kematian</option>
        </select>
      </div>

      <!-- Keperluan -->
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Keperluan / Alasan Pengajuan</label>
        <textarea name="keperluan" required rows="4" placeholder="Contoh: Persyaratan mendaftar beasiswa atau pembukaan rekening bank"
          class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-hijau-400 transition resize-none bg-slate-50"></textarea>
        <p class="mt-2 text-xs text-slate-400 italic">*Mohon jelaskan secara detail agar proses verifikasi lebih cepat.</p>
      </div>

      <!-- Tombol Submit -->
      <div class="pt-4">
        <button type="submit" class="w-full bg-hijau-600 hover:bg-hijau-700 text-white font-bold py-4 rounded-xl transition shadow-md shadow-hijau-100 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          Kirim Pengajuan
        </button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>