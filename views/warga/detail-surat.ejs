<%- include('../partials/header') %>
<%- include('../partials/navbar-warga') %>

<main class="max-w-3xl mx-auto px-4 py-12">
  <div class="mb-8 flex justify-between items-end">
    <div>
      <a href="/warga/dashboard" class="text-hijau-600 hover:text-hijau-700 text-sm font-semibold flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Kembali ke Dashboard
      </a>
      <h1 class="text-3xl font-extrabold text-slate-900">Detail Pengajuan</h1>
      <p class="text-slate-500 font-mono text-sm mt-1">ID: <%= surat.kode_surat %></p>
    </div>
    <div class="text-right">
      <span class="px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest
        <%= surat.status === 'Selesai' ? 'bg-hijau-100 text-hijau-700 border border-hijau-200' : 
            surat.status === 'Diproses' ? 'bg-biru-100 text-biru-700 border border-biru-200' : 
            surat.status === 'Ditolak' ? 'bg-red-100 text-red-700 border border-red-200' : 
            'bg-amber-100 text-amber-700 border border-amber-200' %>">
        <%= surat.status %>
      </span>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="p-8 border-b border-slate-100">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Jenis Surat</p>
          <p class="text-lg font-bold text-slate-800"><%= surat.jenis_surat %></p>
        </div>
        <div>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Tanggal Pengajuan</p>
          <p class="text-slate-800 font-medium"><%= new Date(surat.tanggal_pengajuan).toLocaleDateString('id-ID', { dateStyle: 'full' }) %></p>
        </div>
        <div class="md:col-span-2">
          <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Keperluan</p>
          <p class="text-slate-700 leading-relaxed bg-slate-50 p-4 rounded-xl border border-slate-100"><%= surat.keperluan %></p>
        </div>
      </div>
    </div>
    
    <% if (surat.catatan_admin) { %>
    <div class="p-8 bg-amber-50">
      <p class="text-xs font-bold text-amber-600 uppercase tracking-wider mb-2 flex items-center gap-1">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
        Catatan dari Admin Desa
      </p>
      <p class="text-amber-800 italic font-medium">"<%= surat.catatan_admin %>"</p>
    </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>