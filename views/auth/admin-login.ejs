<%- include('../partials/header') %>

<div class="min-h-screen bg-slate-900 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 mb-4">
        <div class="w-10 h-10 bg-hijau-500 rounded-xl flex items-center justify-center shadow-lg shadow-hijau-900/20">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <span class="font-extrabold text-white text-xl tracking-tight">DesaConnect <span class="text-hijau-500">Admin</span></span>
      </a>
      <h1 class="text-2xl font-bold text-white">Panel Administrasi</h1>
      <p class="text-slate-400 text-sm mt-1">Gunakan akun petugas untuk masuk</p>
    </div>

    <div class="bg-slate-800 rounded-2xl shadow-2xl border border-slate-700 p-8">
      <%- include('../partials/flash') %>
      
      <form action="/auth/admin-login" method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-semibold text-slate-300 mb-1.5">Username</label>
          <input type="text" name="username" required placeholder="admin_sukamaju"
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-hijau-500 focus:border-transparent transition">
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-300 mb-1.5">Password</label>
          <input type="password" name="password" required placeholder="••••••••"
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-hijau-500 focus:border-transparent transition">
        </div>
        <button type="submit" class="w-full bg-hijau-600 hover:bg-hijau-700 text-white font-bold py-3.5 rounded-xl transition shadow-lg shadow-hijau-900/20">
          Masuk ke Dashboard
        </button>
      </form>
      
      <div class="mt-8 pt-6 border-t border-slate-700 text-center">
        <a href="/auth/login" class="text-slate-400 text-xs hover:text-white transition">← Kembali ke Login Warga</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>