<% if (success && success.length) { %>
  <div id="flash-success" class="flex items-start gap-3 bg-hijau-50 border border-hijau-500 text-hijau-800 px-4 py-3 rounded-xl mb-4 shadow-sm">
    <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-hijau-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
    <span class="text-sm font-medium"><%= success[0] %></span>
  </div>
<% } %>
<% if (error && error.length) { %>
  <div id="flash-error" class="flex items-start gap-3 bg-red-50 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-4 shadow-sm">
    <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
    <span class="text-sm font-medium"><%= error[0] %></span>
  </div>
<% } %>
