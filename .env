# DesaConnect Environment Configuration
# Salin file ini menjadi .env dan sesuaikan nilainya

# ======================
# SERVER CONFIGURATION
# ======================
PORT=3000
NODE_ENV=development

# ======================
# DATABASE CONFIGURATION
# ======================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=desaconnect

# ======================
# SESSION & SECURITY
# ======================
SESSION_SECRET=desaconnect_super_secret_key_ganti_ini_di_production

# ======================
# APPLICATION INFO
# ======================
DESA_NAMA=Desa Sukamaju
DESA_KECAMATAN=Kecamatan Cisayong
DESA_KABUPATEN=Kabupaten Tasikmalaya
DESA_PROVINSI=Jawa Barat
